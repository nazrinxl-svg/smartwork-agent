# SmartWork Production Worker Environment Example
# Copy to .env.production.local on VPS/server.
# Never commit real values.

SMARTWORK_RUNTIME=production-worker
SMARTWORK_NODE_ENV=production
SMARTWORK_QUEUE_DIR=data/production-queue
SMARTWORK_ARTIFACTS_DIR=artifacts/production
SMARTWORK_REPORTS_DIR=reports/production-worker

# Browser runtime
SMARTWORK_BROWSER_MODE=headless
SMARTWORK_BROWSER_PROFILE_DIR=/var/lib/smartwork/browser-profile
SMARTWORK_CHROME_EXECUTABLE=

# App/backend
SMARTWORK_APP_BASE_URL=
SMARTWORK_API_BASE_URL=
SMARTWORK_WORKER_TOKEN=

# Storage
SMARTWORK_STORAGE_MODE=local
SMARTWORK_STORAGE_BUCKET=
SMARTWORK_STORAGE_ACCESS_KEY=
SMARTWORK_STORAGE_SECRET_KEY=

# Safety
SMARTWORK_DRY_RUN=true
SMARTWORK_REAL_SAVE_ENABLED=false
SMARTWORK_REAL_SEND_ENABLED=false
